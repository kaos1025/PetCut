# PetCut — required environment variables
# Copy this file to `.env` (which is gitignored) and fill in real values.
#
# - GEMINI_API_KEY:    free-tier label/combo analysis (Gemini Flash).
# - ANTHROPIC_API_KEY: paid 5-section report generation (Claude Sonnet).
#
# Issue your own keys at:
#   - https://aistudio.google.com/apikey
#   - https://platform.claude.com/settings/keys

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
